{
  "name": "deskivo",
  "version": "1.0.0",
  "private": true,
  "description": "Aplicativo desktop Deskivo feito com Electron",
  "keywords": [],
  "homepage": "https://github.com/Gabriel6223684/senac2#readme",
  "bugs": {
    "url": "https://github.com/Gabriel6223684/senac2/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Gabriel6223684/senac2.git"
  },
  "license": "MIT",
  "author": "Gabriel Luiz da Silva",
  "main": "main.js",
  "scripts": {
    "start": "electron-forge start",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:mac": "electron-builder --mac",
    "build:all": "electron-builder --win --linux --mac",
    "package": "electron-forge package",
    "make": "electron-forge make"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "bootstrap": "^5.3.8",
    "datatables.net-bs5": "^2.3.7",
    "datatables.net-responsive-bs5": "^3.0.8",
    "docker": "^1.0.0",
    "dotenv": "^17.3.1",
    "electron-squirrel-startup": "^1.0.1",
    "inputmask": "^5.0.9",
    "jquery": "^4.0.0",
    "knex": "^3.2.7",
    "nunjucks": "^3.2.4",
    "pg": "^8.20.0",
    "sweetalert2": "^11.26.23"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@faker-js/faker": "^10.4.0",
    "electron": "^40.8.5",
    "electron-builder": "^26.8.1",
    "jest": "^30.3.0"
  },
  "build": {
    "appId": "com.deskivo.app",
    "productName": "Deskivo",
    "copyright": "Copyright © 2026 Deskivo",
    "directories": {
      "output": "dist"
    },
    "asar": true,
    "asarUnpack": [
      "app/view/**/*",
      "node_modules/nunjucks/**/*"
    ],
    "files": [
      "app/**/*",
      "main.js",
      "package.json",
      "!app/**/*.map",
      "!app/**/test/**"
    ],
    "extraFiles": [
      {
        "from": ".env.production",
        "to": ".env"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "app/view/pages/assets/img/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Deskivo",
      "installerIcon": "app/view/pages/assets/img/icon.png",
      "uninstallerIcon": "app/view/pages/assets/img/icon.png",
      "installerHeaderIcon": "app/view/pages/assets/img/icon.png"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "app/view/pages/assets/img/icon.png",
      "category": "Office"
    }
  }
}
